# Resend API key — get yours at https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# Where contact form submissions are delivered
CONTACT_TO_EMAIL=hello@upwardphysio.com

# The "from" address. Must be a verified domain on Resend.
# For local testing you can use Resend's onboarding sender: onboarding@resend.dev
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Public site URL (used for SEO metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
